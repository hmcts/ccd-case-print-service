{
  "name": "ccd-case-print-service",
  "version": "1.2.0",
  "private": true,
  "engines": {
    "node": "^24.15.0"
  },
  "scripts": {
    "setup": "NODE_PATH=. yarn sass",
    "start": "NODE_PATH=. yarn tsx server.js",
    "develop": "NODE_PATH=. echo \"develop\" & yarn sass:watch & yarn tsx watch --include src/main server.js",
    "debug": "NODE_PATH=. LOG_LEVEL=DEBUG yarn develop",
    "lint": "eslint .",
    "sass": "NODE_PATH=. sass src/main/public/stylesheets/app.scss:src/main/public/stylesheets/app.css --source-map --style=expanded --quiet --load-path=node_modules",
    "test:base": "NODE_ENV=test LOG_LEVEL=OFF mocha --reporter mochawesome --reporter-options reportFilename=unit,inlineAssets=true,reportTitle=ccd-case-print-service-unit --exit --import=tsx",
    "test": "yarn test:base 'src/**/*.ts' --ignore '**/a11y/**'",
    "test:specific": "NODE_ENV=test LOG_LEVEL=DEBUG mocha --exit --import=tsx",
    "test:coverage": "NODE_ENV=test LOG_LEVEL=OFF nyc mocha --exit --import=tsx 'src/**/*.ts' --ignore '**/a11y/**'",
    "test:routes": "NODE_ENV=test LOG_LEVEL=OFF mocha --import=tsx $(find src/test \\( -name '*.ts' -or -name '*.js' \\) -path '*/routes/*') --reporter mochawesome --reporter-options reportFilename=routes,inlineAssets=true,reportTitle=ccd-case-print-service-routes",
    "test:a11y": "PUPPETEER_SKIP_DOWNLOAD=false PUPPETEER_SKIP_CHROME_DOWNLOAD=false PUPPETEER_SKIP_CHROME_HEADLESS_SHELL_DOWNLOAD=true node node_modules/puppeteer/install.mjs && NODE_ENV=test NODE_PATH=. LOG_LEVEL=INFO mocha --import=tsx 'src/test/a11y/**' --timeout 60000 --exit --reporter mochawesome --reporter-options reportFilename=a11y,inlineAssets=true,reportTitle=ccd-case-print-service-a11y",
    "test:unit": "NODE_ENV=test LOG_LEVEL=OFF mocha --reporter mochawesome --reporter-options reportFilename=unit,inlineAssets=true,reportTitle=ccd-case-print-service-unit --exit --import=tsx",
    "test:acceptance": "echo 'TODO - CALL JAVA INTEGRATION TEST'",
    "test:smoke": "echo 'TODO - Ignore SMOKE tests'",
    "test:functional": "./aat/gradlew -p aat functional",
    "fortifyScan": "./aat/gradlew -p aat fortifyScan",
    "suppress-cve": "yarn npm audit --recursive --environment production --json > yarn-audit-known-issues",
    "sonar-scan": "NODE_PATH=. sonar-scanner -X",
    "highLevelDataSetup": "echo './aat/gradlew -p aat highLevelDataSetup --args=$1' > ./temp.sh && sh ./temp.sh",
    "snyk-protect": "snyk-protect",
    "prepare": "npm run snyk-protect"
  },
  "dependencies": {
    "@dr.pogodin/csurf": "^1.16.9",
    "@hmcts/nodejs-healthcheck": "^1.8.6",
    "@hmcts/nodejs-logging": "^4.0.4",
    "@hmcts/properties-volume": "^1.4.0",
    "@snyk/protect": "^1.1304.0",
    "@types/node": "^24.12.2",
    "applicationinsights": "^3.14.0",
    "assign-deep": "^1.0.1",
    "body-parser": "^2.2.2",
    "brace-expansion": "^5.0.5",
    "config": "^4.4.1",
    "cookie": "1.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.22.1",
    "express-nunjucks": "^3.1.2",
    "form-data": "^4.0.5",
    "govuk-frontend": "^5.14.0",
    "helmet": "^8.1.0",
    "jquery": "^4.0.0",
    "js-yaml": "^4.1.1",
    "jwt-decode": "^4.0.0",
    "mime": "^4.1.0",
    "node-fetch": "^3.3.2",
    "nunjucks": "^3.2.4",
    "nunjucks-date-filter": "^0.1.1",
    "nunjucks-numeral-filter": "^0.0.2",
    "otp": "^0.1.3",
    "require-directory": "^2.1.1",
    "sass": "^1.99.0",
    "serve-favicon": "^2.5.1",
    "tar": "^7.5.15"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/body-parser": "^1.19.6",
    "@types/chai-as-promised": "^8.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/require-directory": "^2.1.7",
    "@types/serve-favicon": "^2.5.7",
    "@types/sinon-chai": "^4.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "code-point-at": "^1.0.0",
    "debug": "^4.4.3",
    "es6-promisify": "^7.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-mocha": "^11.2.0",
    "globals": "^17.5.0",
    "jasmine-core": "^6.2.0",
    "jasmine-spec-reporter": "^7.0.0",
    "json-loader": "^0.5.7",
    "json-server": "^1.0.0-beta.15",
    "jsonwebtoken": "^9.0.3",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "moment": "^2.30.1",
    "nock": "^14.0.13",
    "node-mocks-http": "^1.17.2",
    "nyc": "^18.0.0",
    "pa11y": "^9.1.1",
    "proxyquire": "^2.1.3",
    "sinon": "^21.1.2",
    "sinon-chai": "^4.0.1",
    "sonar-scanner": "^3.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "webpack": "^5.106.2"
  },
  "snyk": true,
  "nyc": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/main"
    ],
    "exclude": [
      "**/*.d.ts",
      "src/main/public",
      "src/main/modules",
      "src/main/router",
      "src/main/util",
      "src/main/app.ts",
      "src/main/server.ts"
    ],
    "reporter": [
      "lcov",
      "text-summary",
      "html"
    ],
    "sourceMap": true,
    "instrument": true,
    "report-dir": "coverage",
    "all": true
  },
  "packageManager": "yarn@4.15.0"
}
